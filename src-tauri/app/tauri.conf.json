{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Task Progress Tracker",
  "version": "0.1.0",
  "identifier": "com.seong.tasktracker",
  "build": {
    "beforeDevCommand": "npm run --prefix ../.. dev",
    "beforeBuildCommand": "npm run --prefix ../.. build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Task Progress Tracker",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
